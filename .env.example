# Локальная PostgreSQL (Docker или установленная)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/app_db

# Supabase (на другом ПК / Vercel — после `npx vercel env pull .env.local`)
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
# POSTGRES_URL_NON_POOLING=postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
